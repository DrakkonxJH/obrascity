NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# Local dev / replace with Netlify URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Billing
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER_IDS=price_xxx
STRIPE_PRICE_ENTERPRISE_IDS=price_yyy

# Signup / email / security
SIGNUP_EDGE_SHARED_SECRET=YOUR_SIGNUP_EDGE_SHARED_SECRET
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL="ObrasFlow <no-reply@obrasflow.com>"
DATA_ENCRYPTION_KEY=YOUR_32_BYTE_KEY_BASE64_OR_HEX

# Controle total (somente um admin dono)
CONTROLE_TOTAL_OWNER_EMAIL=seu-email-admin@dominio.com
# Opcional: use o id do profile em vez do e-mail
CONTROLE_TOTAL_OWNER_PROFILE_ID=

# CRM gateway (modo WeKan interno)
# native = CRM nativo do app | wekan_proxy = proxy para WeKan interno
CRM_MODE=native
# Ex.: http://wekan-internal:8080
CRM_INTERNAL_URL=
# segredo para assinar x-obrasflow-auth no proxy
CRM_PROXY_SHARED_SECRET=
